{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
   "target": "es2020",
   "module": "commonjs",
   "lib": ["es2020"],
   "outDir": "./dist",
   "rootDir": "./src",
   "strict": true,
   "esModuleInterop": true,
   "skipLibCheck": true,
   "forceConsistentCasingInFileNames": true,
   "resolveJsonModule": true,
   "baseUrl": "./src",
   "paths": {
    "_helpers/*": ["_helpers/*"],
    "_middleware/*": ["_middleware/*"],
    "users/*": ["users/*"]
   }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
